state.ahubhdmi {
	control.1 {
		iface MIXER
		name 'loopback debug'
		value false
		comment {
			access 'read write'
			type BOOLEAN
			count 1
		}
	}
	control.2 {
		iface MIXER
		name 'audio data format'
		value NULL
		comment {
			access 'read write'
			type ENUMERATED
			count 1
			item.0 NULL
			item.1 PCM
			item.2 AC3
			item.3 MPEG1
			item.4 MP3
			item.5 MPEG2
			item.6 AAC
			item.7 DTS
			item.8 ATRAC
			item.9 ONE_BIT_AUDIO
			item.10 DOLBY_DIGITAL_PLUS
			item.11 DTS_HD
			item.12 MAT
			item.13 DST
			item.14 WMAPRO
		}
	}
}
