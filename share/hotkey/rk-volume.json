{
  "devices": [
    "rk-g350-v"
  ],
  "VOL_DOWN": {
    "handle_hold": true,
    "inputs": [
      "VOL_DOWN"
    ],
    "negate": [
      "MENU_SHORT"
    ],
    "run_command": "/opt/muos/script/device/audio.sh D"
  },
  "VOL_UP": {
    "handle_hold": true,
    "inputs": [
      "VOL_UP"
    ],
    "negate": [
      "MENU_SHORT"
    ],
    "run_command": "/opt/muos/script/device/audio.sh U"
  }
}
